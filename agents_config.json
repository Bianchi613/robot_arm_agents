{
  "llm": {
    "provider": "ollama",
    "model": "qwen2.5-coder:7b",
    "base_url": "http://localhost:11434",
    "timeout_seconds": 30,
    "enabled": true,
    "fallback_to_rule_parser": false
  },
  "SupervisorAgent": {
    "role": "Mission manager",
    "responsibilities": [
      "Receive the user command",
      "Interpret simple commands",
      "Read the current robot state",
      "Create the movement intention",
      "Request proposals from joint agents",
      "Validate the final plan",
      "Send the plan to the robot",
      "Receive feedback"
    ],
    "can_do": [
      "Accept or reject plans for safety",
      "Send commands to MockRobot or ArduinoRobot"
    ],
    "cannot_do": [
      "Move servos directly",
      "Ignore joint limits"
    ]
  },
  "BaseJointAgent": {
    "role": "Base joint agent",
    "limits": {
      "min_angle": 0,
      "max_angle": 180
    },
    "responsibilities": [
      "Handle horizontal rotation",
      "Suggest the base angle",
      "Check base limits",
      "Report when the base cannot perform the move"
    ]
  },
  "ShoulderJointAgent": {
    "role": "Shoulder joint agent",
    "limits": {
      "min_angle": 20,
      "max_angle": 160
    },
    "responsibilities": [
      "Handle the main lift/lower motion",
      "Suggest the shoulder angle",
      "Avoid lowering too far",
      "Check shoulder limits"
    ]
  },
  "ElbowJointAgent": {
    "role": "Elbow joint agent",
    "limits": {
      "min_angle": 15,
      "max_angle": 165
    },
    "responsibilities": [
      "Handle arm reach",
      "Suggest extension or retraction",
      "Check elbow limits",
      "Avoid dangerous extension"
    ]
  },
  "WristJointAgent": {
    "role": "Wrist joint agent",
    "limits": {
      "min_angle": 0,
      "max_angle": 180
    },
    "responsibilities": [
      "Handle gripper tilt",
      "Keep the gripper aligned",
      "Compensate shoulder and elbow motion",
      "Check wrist limits"
    ]
  },
  "GripperAgent": {
    "role": "Gripper agent",
    "limits": {
      "open_angle": 80,
      "closed_angle": 25
    },
    "responsibilities": [
      "Open the gripper",
      "Close the gripper",
      "Hold the piece",
      "Release the piece",
      "Avoid crushing the piece"
    ]
  },
  "MotionCoordinatorAgent": {
    "role": "Technical motion coordinator",
    "responsibilities": [
      "Receive proposals from JointAgents",
      "Merge proposals",
      "Detect conflicts",
      "Correct simple conflicts",
      "Synchronize speeds",
      "Generate the complete plan",
      "Return the plan to SupervisorAgent"
    ]
  }
}
